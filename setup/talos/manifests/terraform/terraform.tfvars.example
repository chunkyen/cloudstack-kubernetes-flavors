# ──────────────────────────────────────────────
# Talos on CloudStack — Terraform Variables
# ──────────────────────────────────────────────
# Copy this file to terraform.tfvars and fill in your values.
# Sensitive values (API keys) go in environment variables:
#   export CLOUDSTACK_API_URL=http://192.168.200.1:8080/client/api
#   export CLOUDSTACK_API_KEY=your-api-key
#   export CLOUDSTACK_SECRET_KEY=your-secret-key

zone_id                    = "<zone-uuid>"
template_id                = "<talos-template-uuid>"
network_offering_id        = "<kubernetes-network-offering-uuid>"
control_plane_offering_id  = "<kube-control-offering-uuid>"
worker_offering_id         = "<kube-worker-offering-uuid>"

# Generated by: talosctl gen config <name> https://<public-ip>:6443 ...
# Then base64-encoded:
#   base64 controlplane.yaml | tr -d '\n'
control_plane_userdata   = "<base64-encoded-controlplane.yaml>"
worker_userdata          = "<base64-encoded-worker.yaml>"

# Optional overrides
# cluster_name          = "talos-cluster"
# control_plane_count   = 1
# worker_count          = 1
# network_cidr          = "10.22.2.0/24"
# network_gateway       = "10.22.2.1"
